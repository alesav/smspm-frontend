<script define:vars={{ lang, translations }}>
  const t = translations[lang] || translations.en;
  
  // GSM charset
  const GSM_7BIT_BASIC = '@£$¥èéùìòÇ\nØø\rÅåΔ_ΦΓΛΩΠΨΣΘΞÆæßÉ !"#¤%&\'()*+,-./0123456789:;<=>?¡ABCDEFGHIJKLMNOPQRSTUVWXYZÄÖÑÜ§¿abcdefghijklmnopqrstuvwxyzäöñüà';
  const GSM_7BIT_EXTENDED = '|^€{}[]~\\';
  
  const UNICODE_TO_GSM = {
    "\u201C": '"', "\u201D": '"', "\u2018": "'", "\u2019": "'",
    '—': '-', '–': '-', '…': '...',
    '•': '*', '°': 'o', '×': 'x', '÷': '/',
    '™': '(TM)', '©': '(c)', '®': '(R)'
  };
  
  function analyzeText(text) {
    let basicCount = 0, extendedCount = 0, unicodeCount = 0;
    let gsmLength = 0;
    const nonGsmChars = [];
    
    for (let i = 0; i < text.length; i++) {
      const char = text[i];
      
      if (GSM_7BIT_BASIC.includes(char)) {
        basicCount++;
        gsmLength++;
      } else if (GSM_7BIT_EXTENDED.includes(char)) {
        extendedCount++;
        gsmLength += 2;
      } else {
        unicodeCount++;
        const charCode = char.charCodeAt(0);
        const unicodeStr = 'U+' + charCode.toString(16).toUpperCase().padStart(4, '0');
        const suggestion = UNICODE_TO_GSM[char] || '-';
        nonGsmChars.push({ char, position: i + 1, unicode: unicodeStr, suggestion });
      }
    }
    
    const isGsm = unicodeCount === 0;
    const encoding = isGsm ? 'GSM-7' : 'Unicode';
    const charLimit = isGsm ? (gsmLength <= 160 ? 160 : 153) : (text.length <= 70 ? 70 : 67);
    const smsCount = text.length === 0 ? 0 : Math.ceil((isGsm ? gsmLength : text.length) / charLimit);
    
    return {
      basicCount, extendedCount, unicodeCount, gsmLength,
      isGsm, encoding, smsCount, charLimit, nonGsmChars, text
    };
  }
  
  const inputText = document.getElementById('inputText');
  const analyzeBtn = document.getElementById('analyzeBtn');
  const clearBtn = document.getElementById('clearBtn');
  const resultsSection = document.getElementById('resultsSection');
  const statusCard = document.getElementById('statusCard');
  const statusIcon = document.getElementById('statusIcon');
  const statusTitle = document.getElementById('statusTitle');
  const statusDesc = document.getElementById('statusDesc');
  const nonGsmSection = document.getElementById('nonGsmSection');
  const charTableBody = document.getElementById('charTableBody');
  const replaceAllBtn = document.getElementById('replaceAllBtn');
  const basicCount = document.getElementById('basicCount');
  const extendedCount = document.getElementById('extendedCount');
  const unicodeCount = document.getElementById('unicodeCount');
  const totalCharsVal = document.getElementById('totalCharsVal');
  const gsmLengthVal = document.getElementById('gsmLengthVal');
  const encodingVal = document.getElementById('encodingVal');
  const smsCountVal = document.getElementById('smsCountVal');
  const charsPerSmsVal = document.getElementById('charsPerSmsVal');
  const recommendationBox = document.getElementById('recommendationBox');
  
  function displayResults(analysis) {
    resultsSection.style.display = 'flex';
    
    // Status card
    statusCard.className = `status-card ${analysis.isGsm ? 'gsm' : 'unicode'}`;
    statusTitle.textContent = analysis.isGsm ? t.gsmCompatible : t.unicodeRequired;
    statusDesc.textContent = analysis.isGsm ? t.gsmDesc : t.unicodeDesc;
    
    if (analysis.isGsm) {
      statusIcon.innerHTML = '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill="currentColor"/>';
    } else {
      statusIcon.innerHTML = '<path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" fill="currentColor"/>';
    }
    
    // Non-GSM chars table
    if (!analysis.isGsm && analysis.nonGsmChars.length > 0) {
      nonGsmSection.style.display = 'block';
      charTableBody.innerHTML = analysis.nonGsmChars.map(item => `
        <tr>
          <td>${item.position}</td>
          <td>
            <div class="char-display">${item.char}</div>
            <div class="unicode-code">${item.unicode}</div>
          </td>
          <td>${item.unicode}</td>
          <td class="suggestion">${item.suggestion}</td>
          <td>
            ${item.suggestion !== '-' ? `
              <button class="btn-replace" data-char="${item.char}" data-replacement="${item.suggestion}">
                ${t.replace}
              </button>
            ` : ''}
          </td>
        </tr>
      `).join('');
      
      document.querySelectorAll('.btn-replace').forEach(btn => {
        btn.addEventListener('click', () => {
          const char = btn.dataset.char;
          const replacement = btn.dataset.replacement;
          inputText.value = inputText.value.replace(new RegExp(char, 'g'), replacement);
          analyzeBtn.click();
          
          if (typeof umami !== 'undefined') {
            umami.track('Character Replaced', { from: char, to: replacement });
          }
        });
      });
    } else {
      nonGsmSection.style.display = 'none';
    }
    
    // Breakdown
    basicCount.textContent = analysis.basicCount;
    extendedCount.textContent = analysis.extendedCount;
    unicodeCount.textContent = analysis.unicodeCount;
    
    // Stats
    totalCharsVal.textContent = analysis.text.length;
    gsmLengthVal.textContent = analysis.gsmLength;
    encodingVal.textContent = analysis.encoding;
    smsCountVal.textContent = analysis.smsCount;
    charsPerSmsVal.textContent = analysis.charLimit;
    
    // Recommendation
    recommendationBox.className = `recommendation-box ${analysis.isGsm ? 'gsm' : 'unicode'}`;
    recommendationBox.textContent = analysis.isGsm ? t.useGsm : t.convertToGsm;
  }
  
  analyzeBtn.addEventListener('click', () => {
    const text = inputText.value;
    if (!text) return;
    
    const analysis = analyzeText(text);
    displayResults(analysis);
    
    if (typeof umami !== 'undefined') {
      umami.track('Encoding Checked', {
        encoding: analysis.encoding,
        unicodeChars: analysis.unicodeCount,
        messages: analysis.smsCount
      });
    }
  });
  
  clearBtn.addEventListener('click', () => {
    inputText.value = '';
    resultsSection.style.display = 'none';
  });
  
  replaceAllBtn.addEventListener('click', () => {
    let text = inputText.value;
    for (const [from, to] of Object.entries(UNICODE_TO_GSM)) {
      text = text.replace(new RegExp(from, 'g'), to);
    }
    inputText.value = text;
    analyzeBtn.click();
    
    if (typeof umami !== 'undefined') {
      umami.track('Replace All Used');
    }
  });
</script>
