const t = translations[lang] || translations.en;
---

<div class="checker-container">
  <div class="checker-header">
    <h2 class="checker-title">{t.title}</h2>
    <p class="checker-subtitle">{t.subtitle}</p>
  </div>

  <div class="checker-body">
    <!-- Input Section -->
    <div class="input-section">
      <textarea
        id="inputText"
        class="checker-input"
        placeholder={t.placeholder}
        rows="6"
      ></textarea>
      
      <div class="input-actions">
        <button id="analyzeBtn" class="btn-analyze">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z" fill="currentColor"/>
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm9.707 5.707a1 1 0 00-1.414-1.414L9 12.586l-1.293-1.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill="currentColor"/>
          </svg>
          {t.analyzeButton}
        </button>
        <button id="clearBtn" class="btn-secondary">{t.clear}</button>
      </div>
    </div>

    <!-- Results Section -->
    <div id="resultsSection" class="results-section" style="display: none;">
      <!-- Encoding Status -->
      <div id="statusCard" class="status-card">
        <div class="status-icon">
          <svg id="statusIcon" width="48" height="48" viewBox="0 0 20 20" fill="none">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill="currentColor"/>
          </svg>
        </div>
        <div class="status-content">
          <h3 id="statusTitle">{t.gsmCompatible}</h3>
          <p id="statusDesc">{t.gsmDesc}</p>
        </div>
      </div>

      <!-- Non-GSM Characters Table -->
      <div id="nonGsmSection" class="non-gsm-section" style="display: none;">
        <div class="section-header">
