            <thead>
              <tr>
                <th>{t.position}</th>
                <th>{t.character}</th>
                <th>{t.unicode}</th>
                <th>{t.suggestion}</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="charTableBody"></tbody>
          </table>
        </div>
      </div>

      <!-- Character Breakdown -->
      <div class="breakdown-section">
        <h3>{t.characterBreakdown}</h3>
        <div class="breakdown-grid">
