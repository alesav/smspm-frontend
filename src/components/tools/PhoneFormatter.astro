---

<div class="formatter-container">
  <div class="formatter-header">
    <h2 class="formatter-title">{t.title}</h2>
    <p class="formatter-subtitle">{t.subtitle}</p>
  </div>

  <div class="formatter-body">
    <div class="input-section">
      <div class="input-wrapper">
        <input
          type="tel"
          id="phoneInput"
          class="phone-input"
          placeholder={t.placeholder}
          autocomplete="tel"
        />
        <button id="pasteBtn" class="btn-paste" title={t.paste}>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z" fill="currentColor"/>
            <path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" fill="currentColor"/>
          </svg>
        </button>
      </div>
      <div class="input-actions">
        <button id="formatBtn" class="btn-format">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill="currentColor"/>
          </svg>
          {t.format}
        </button>
        <button id="clearBtn" class="btn-secondary">{t.clear}</button>
      </div>
    </div>

    <div id="resultsSection" class="results-section" style="display: none;">
      <div id="statusCard" class="status-card">
        <div class="status-icon">
          <svg id="statusIcon" width="48" height="48" viewBox="0 0 20 20" fill="none">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill="currentColor"/>
          </svg>
        </div>
        <div class="status-content">
          <h3 id="statusTitle">{t.valid}</h3>
          <p id="statusDesc">{t.validDesc}</p>
        </div>
      </div>

      <div class="formatted-section">
        <h3>{t.formatted}</h3>
        <div class="formatted-grid">
          <div class="formatted-card">
            <div class="formatted-label">{t.e164}</div>
            <div class="formatted-value-wrapper">
              <div id="e164Value" class="formatted-value">+1234567890</div>
              <button class="btn-copy" data-copy="e164" title={t.copy}>
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                  <path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z" fill="currentColor"/>
                  <path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="formatted-card">
            <div class="formatted-label">{t.national}</div>
            <div class="formatted-value-wrapper">
              <div id="nationalValue" class="formatted-value">(123) 456-7890</div>
              <button class="btn-copy" data-copy="national" title={t.copy}>
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                  <path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z" fill="currentColor"/>
                  <path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="formatted-card">
            <div class="formatted-label">{t.international}</div>
            <div class="formatted-value-wrapper">
              <div id="internationalValue" class="formatted-value">+1 123 456 7890</div>
              <button class="btn-copy" data-copy="international" title={t.copy}>
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none">
                  <path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z" fill="currentColor"/>
                  <path d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2V5z" fill="currentColor"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <div class="info-section">
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">{t.countryDetected}</span>
            <span id="countryName" class="info-value">United States</span>
          </div>
          <div class="info-item">
            <span class="info-label">{t.countryCode}</span>
            <span id="countryCodeVal" class="info-value">+1</span>
          </div>
          <div class="info-item">
            <span class="info-label">{t.numberLength}</span>
            <span id="numberLength" class="info-value">10</span>
          </div>
          <div class="info-item">
            <span class="info-label">{t.numberType}</span>
            <span id="numberType" class="info-value">{t.mobile}</span>
          </div>
        </div>
      </div>

      <div class="tips-section">
        <h3>{t.tips}</h3>
        <ul class="tips-list">
          <li>{t.tip1}</li>
          <li>{t.tip2}</li>
          <li>{t.tip3}</li>
          <li>{t.tip4}</li>
        </ul>
      </div>

      <div class="examples-section">
        <h3>{t.examples}</h3>
        <ul class="examples-list">
          <li>{t.exampleUS}</li>
          <li>{t.exampleUK}</li>
          <li>{t.exampleEE}</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .formatter-container { max-width: 900px; margin: 0 auto; padding: 2rem; }
  .formatter-header { text-align: center; margin-bottom: 2rem; }
  .formatter-title { font-size: 2rem; font-weight: 700; color: var(--text-primary, #1a1a1a); margin-bottom: 0.5rem; }
  .formatter-subtitle { font-size: 1.125rem; color: var(--text-secondary, #666); }
  .formatter-body { background: white; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
  .input-wrapper { position: relative; display: flex; align-items: center; }
  .phone-input { flex: 1; padding: 1rem; padding-right: 3rem; font-size: 1.125rem; font-weight: 500; font-family: 'Courier New', monospace; border: 2px solid #e5e7eb; border-radius: 12px; transition: border-color 0.2s; }
  .phone-input:focus { outline: none; border-color: #26c6da; }
  .btn-paste { position: absolute; right: 0.5rem; padding: 0.5rem; background: transparent; border: none; color: #6b7280; cursor: pointer; border-radius: 6px; transition: background 0.2s, color 0.2s; }
  .btn-paste:hover { background: #f3f4f6; color: #374151; }
  .input-actions { display: flex; gap: 1rem; margin-top: 1rem; }
  .btn-format { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.875rem 1.5rem; background: linear-gradient(135deg, #26c6da 0%, #1e88e5 100%); color: white; font-size: 1rem; font-weight: 600; border: none; border-radius: 8px; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; }
  .btn-format:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(38,198,218,0.3); }
  .btn-secondary { padding: 0.875rem 1.5rem; background: #f3f4f6; color: #374151; font-size: 1rem; font-weight: 600; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s; }
  .btn-secondary:hover { background: #e5e7eb; }
  .results-section { display: flex; flex-direction: column; gap: 2rem; margin-top: 2rem; }
  .status-card { display: flex; align-items: center; gap: 1.5rem; padding: 2rem; border-radius: 12px; border: 2px solid; }
  .status-card.valid { background: #ecfdf5; border-color: #10b981; }
  .status-card.invalid { background: #fee2e2; border-color: #ef4444; }
  .status-icon { flex-shrink: 0; width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; background: white; border-radius: 50%; }
  .status-card.valid .status-icon { color: #10b981; }
  .status-card.invalid .status-icon { color: #ef4444; }
  .status-content h3 { font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem; }
  .status-card.valid h3 { color: #065f46; }
  .status-card.invalid h3 { color: #991b1b; }
  .status-content p { color: #6b7280; line-height: 1.6; }
  .formatted-section h3, .info-section h3, .tips-section h3, .examples-section h3 { font-size: 1.125rem; font-weight: 700; margin-bottom: 1rem; }
  .formatted-grid { display: grid; gap: 1rem; }
  .formatted-card { padding: 1.25rem; background: #f9fafb; border-radius: 12px; border: 1px solid #e5e7eb; }
  .formatted-label { font-size: 0.875rem; color: #6b7280; font-weight: 600; margin-bottom: 0.5rem; }
  .formatted-value-wrapper { display: flex; align-items: center; justify-content: space-between; }
  .formatted-value { font-size: 1.25rem; font-weight: 700; font-family: 'Courier New', monospace; color: #1f2937; }
  .btn-copy { padding: 0.5rem; background: transparent; border: none; color: #6b7280; cursor: pointer; border-radius: 6px; transition: background 0.2s, color 0.2s; }
  .btn-copy:hover { background: white; color: #26c6da; }
  .info-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
  .info-item { display: flex; justify-content: space-between; padding: 1rem; background: #f9fafb; border-radius: 8px; }
  .info-label { font-size: 0.875rem; color: #6b7280; font-weight: 500; }
  .info-value { font-size: 1rem; font-weight: 700; color: #1f2937; }
  .tips-section, .examples-section { padding: 1.5rem; background: #f0f9ff; border-radius: 12px; }
  .tips-list, .examples-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .tips-list li, .examples-list li { padding-left: 1.5rem; position: relative; color: #0369a1; font-size: 0.875rem; }
  .tips-list li::before { content: "✓"; position: absolute; left: 0; color: #0ea5e9; font-weight: 700; }
  .examples-list li::before { content: "•"; position: absolute; left: 0; color: #0ea5e9; font-weight: 700; font-size: 1.25rem; }
  @media (max-width: 768px) {
    .formatter-container { padding: 1rem; }
    .formatter-body { padding: 1.5rem; }
    .input-actions { flex-direction: column; }
    .info-grid { grid-template-columns: 1fr; }
    .status-card { flex-direction: column; text-align: center; }
  }
</style>

<script define:vars={{ lang, translations }}>
  const t = translations[lang] || translations.en;
  const COUNTRY_CODES = {'1':'United States / Canada','7':'Russia / Kazakhstan','20':'Egypt','27':'South Africa','30':'Greece','31':'Netherlands','32':'Belgium','33':'France','34':'Spain','36':'Hungary','39':'Italy','40':'Romania','41':'Switzerland','43':'Austria','44':'United Kingdom','45':'Denmark','46':'Sweden','47':'Norway','48':'Poland','49':'Germany','51':'Peru','52':'Mexico','53':'Cuba','54':'Argentina','55':'Brazil','56':'Chile','57':'Colombia','58':'Venezuela','60':'Malaysia','61':'Australia','62':'Indonesia','63':'Philippines','64':'New Zealand','65':'Singapore','66':'Thailand','81':'Japan','82':'South Korea','84':'Vietnam','86':'China','90':'Turkey','91':'India','92':'Pakistan','93':'Afghanistan','94':'Sri Lanka','95':'Myanmar','98':'Iran','212':'Morocco','213':'Algeria','216':'Tunisia','218':'Libya','220':'Gambia','221':'Senegal','222':'Mauritania','223':'Mali','224':'Guinea','225':'Ivory Coast','226':'Burkina Faso','227':'Niger','228':'Togo','229':'Benin','230':'Mauritius','231':'Liberia','232':'Sierra Leone','233':'Ghana','234':'Nigeria','235':'Chad','236':'Central African Republic','237':'Cameroon','238':'Cape Verde','239':'Sao Tome and Principe','240':'Equatorial Guinea','241':'Gabon','242':'Republic of the Congo','243':'Democratic Republic of the Congo','244':'Angola','245':'Guinea-Bissau','248':'Seychelles','249':'Sudan','250':'Rwanda','251':'Ethiopia','252':'Somalia','253':'Djibouti','254':'Kenya','255':'Tanzania','256':'Uganda','257':'Burundi','258':'Mozambique','260':'Zambia','261':'Madagascar','262':'Reunion','263':'Zimbabwe','264':'Namibia','265':'Malawi','266':'Lesotho','267':'Botswana','268':'Eswatini','269':'Comoros','291':'Eritrea','297':'Aruba','298':'Faroe Islands','299':'Greenland','350':'Gibraltar','351':'Portugal','352':'Luxembourg','353':'Ireland','354':'Iceland','355':'Albania','356':'Malta','357':'Cyprus','358':'Finland','359':'Bulgaria','370':'Lithuania','371':'Latvia','372':'Estonia','373':'Moldova','374':'Armenia','375':'Belarus','376':'Andorra','377':'Monaco','380':'Ukraine','381':'Serbia','382':'Montenegro','385':'Croatia','386':'Slovenia','387':'Bosnia and Herzegovina','389':'North Macedonia','420':'Czech Republic','421':'Slovakia','501':'Belize','502':'Guatemala','503':'El Salvador','504':'Honduras','505':'Nicaragua','506':'Costa Rica','507':'Panama','509':'Haiti','591':'Bolivia','592':'Guyana','593':'Ecuador','595':'Paraguay','597':'Suriname','598':'Uruguay','670':'East Timor','673':'Brunei','675':'Papua New Guinea','676':'Tonga','677':'Solomon Islands','678':'Vanuatu','679':'Fiji','680':'Palau','685':'Samoa','686':'Kiribati','687':'New Caledonia','689':'French Polynesia','850':'North Korea','852':'Hong Kong','853':'Macau','855':'Cambodia','856':'Laos','880':'Bangladesh','886':'Taiwan','960':'Maldives','961':'Lebanon','962':'Jordan','963':'Syria','964':'Iraq','965':'Kuwait','966':'Saudi Arabia','967':'Yemen','968':'Oman','970':'Palestine','971':'United Arab Emirates','972':'Israel','973':'Bahrain','974':'Qatar','975':'Bhutan','976':'Mongolia','977':'Nepal','992':'Tajikistan','993':'Turkmenistan','994':'Azerbaijan','995':'Georgia','996':'Kyrgyzstan','998':'Uzbekistan'};

  function cleanPhoneNumber(input) { return input.replace(/[\s\-\(\)\.\+]/g, ''); }

  function detectCountryCode(number) {
    if (number.startsWith('00')) number = number.substring(2);
    for (let len = 3; len >= 1; len--) {
      const code = number.substring(0, len);
      if (COUNTRY_CODES[code]) return { code: '+' + code, country: COUNTRY_CODES[code], nationalNumber: number.substring(len) };
    }
    return null;
  }

  function formatPhone(number) {
    const cleaned = cleanPhoneNumber(number);
    let withPlus = cleaned.startsWith('+') ? cleaned : cleaned.startsWith('00') ? '+' + cleaned.substring(2) : '+' + cleaned;
    const detected = detectCountryCode(withPlus.substring(1));
    if (!detected) return { isValid: false, e164: withPlus, national: cleaned, international: withPlus, country: t.unknown, countryCode: '?', numberLength: cleaned.length, type: t.unknown };
    const e164 = `+${detected.code.substring(1)}${detected.nationalNumber}`;
    let national = detected.nationalNumber;
    if (national.length >= 10) national = `(${national.substring(0,3)}) ${national.substring(3,6)}-${national.substring(6)}`;
    else if (national.length >= 7) national = `${national.substring(0,3)}-${national.substring(3)}`;
    let international = `${detected.code} ${detected.nationalNumber}`;
    if (detected.nationalNumber.length >= 10) international = `${detected.code} ${detected.nationalNumber.substring(0,3)} ${detected.nationalNumber.substring(3,6)} ${detected.nationalNumber.substring(6)}`;
    const totalDigits = detected.nationalNumber.length;
    return { isValid: totalDigits >= 7 && totalDigits <= 15, e164, national, international, country: detected.country, countryCode: detected.code, numberLength: totalDigits, type: totalDigits < 9 ? t.unknown : t.mobile };
  }

  const phoneInput = document.getElementById('phoneInput');
  const formatBtn = document.getElementById('formatBtn');
  const clearBtn = document.getElementById('clearBtn');
  const pasteBtn = document.getElementById('pasteBtn');
  const resultsSection = document.getElementById('resultsSection');
  const statusCard = document.getElementById('statusCard');
  const statusIcon = document.getElementById('statusIcon');
  const statusTitle = document.getElementById('statusTitle');
  const statusDesc = document.getElementById('statusDesc');
  const e164Value = document.getElementById('e164Value');
  const nationalValue = document.getElementById('nationalValue');
  const internationalValue = document.getElementById('internationalValue');
  const countryName = document.getElementById('countryName');
  const countryCodeVal = document.getElementById('countryCodeVal');
  const numberLength = document.getElementById('numberLength');
  const numberType = document.getElementById('numberType');

  function displayResults(result) {
    resultsSection.style.display = 'flex';
    statusCard.className = `status-card ${result.isValid ? 'valid' : 'invalid'}`;
    statusTitle.textContent = result.isValid ? t.valid : t.invalid;
    statusDesc.textContent = result.isValid ? t.validDesc : t.invalidDesc;
    statusIcon.innerHTML = result.isValid
      ? '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" fill="currentColor"/>'
      : '<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" fill="currentColor"/>';
    e164Value.textContent = result.e164;
    nationalValue.textContent = result.national;
    internationalValue.textContent = result.international;
    countryName.textContent = result.country;
    countryCodeVal.textContent = result.countryCode;
    numberLength.textContent = result.numberLength;
    numberType.textContent = result.type;
  }

  formatBtn.addEventListener('click', () => {
    const input = phoneInput.value.trim();
    if (!input) return;
    displayResults(formatPhone(input));
  });

  clearBtn.addEventListener('click', () => {
    phoneInput.value = '';
    resultsSection.style.display = 'none';
  });

  pasteBtn.addEventListener('click', async () => {
    try { const text = await navigator.clipboard.readText(); phoneInput.value = text; phoneInput.focus(); } catch(e) {}
  });

  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const map = { e164: e164Value, national: nationalValue, international: internationalValue };
      const el = map[btn.dataset.copy];
      if (!el) return;
      try {
        await navigator.clipboard.writeText(el.textContent);
        const orig = btn.innerHTML;
        btn.innerHTML = t.copied;
        setTimeout(() => btn.innerHTML = orig, 2000);
      } catch(e) {}
    });
  });

  phoneInput.addEventListener('keypress', e => { if (e.key === 'Enter') formatBtn.click(); });
</script>
