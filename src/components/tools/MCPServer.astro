const configJson = `{
  "mcpServers": {
    "smspm": {
      "command": "npx",
      "args": ["smspm-mcp"],
      "env": {
        "SMSPM_HASH": "your-hash-here",
        "SMSPM_TOKEN": "your-token-here"
      }
    }
  }
}`;
---

<div class="mcp-tool">

  <!-- What is MCP -->
  <div class="info-card what-is">
    <div class="info-icon">🤖</div>
    <div>
      <h2 class="info-title">{t.whatIs}</h2>
      <p class="info-desc">{t.whatIsDesc}</p>
    </div>
  </div>

  <!-- Badges -->
  <div class="badges">
    <a href="https://www.npmjs.com/package/smspm-mcp" target="_blank" rel="noopener" class="badge badge-npm">
      <span class="badge-icon">📦</span> {t.npmBadge}
    </a>
    <a href="https://github.com/alesav/smspm-mcp" target="_blank" rel="noopener" class="badge badge-github">
      <span class="badge-icon">⭐</span> {t.githubBadge}
    </a>
  </div>

  <!-- Steps -->
  <div class="steps">

    <!-- Step 1 -->
    <div class="step">
      <div class="step-number">1</div>
      <div class="step-content">
        <h3 class="step-title">{t.step1Title}</h3>
        <p class="step-desc">{t.step1Desc}</p>
        <a href="https://nodejs.org" target="_blank" rel="noopener" class="step-link">nodejs.org →</a>
      </div>
    </div>

    <!-- Step 2 -->
    <div class="step">
      <div class="step-number">2</div>
      <div class="step-content">
        <h3 class="step-title">{t.step2Title}</h3>
        <p class="step-desc">{t.step2Desc}</p>
        <div class="config-paths">
          <div class="config-path">
            <span class="platform-label">{t.macPath}</span>
            <code class="path-code">~/Library/Application Support/Claude/claude_desktop_config.json</code>
          </div>
          <div class="config-path">
            <span class="platform-label">{t.winPath}</span>
            <code class="path-code">%APPDATA%\Claude\claude_desktop_config.json</code>
          </div>
        </div>
        <div class="code-block">
          <div class="code-header">
            <span class="code-lang">json</span>
            <button class="copy-btn" data-code={configJson}>Copy</button>
          </div>
          <pre class="code-pre"><code>{configJson}</code></pre>
        </div>
      </div>
    </div>

    <!-- Step 3 -->
    <div class="step">
      <div class="step-number">3</div>
      <div class="step-content">
        <h3 class="step-title">{t.step3Title}</h3>
        <p class="step-desc">{t.step3Desc}</p>
        <div class="credential-hint">
          <p>{t.getCredentialsDesc}</p>
          <a href="https://app.smspm.com" target="_blank" rel="noopener" class="cta-btn">{t.loginBtn}</a>
        </div>
      </div>
    </div>

    <!-- Step 4 -->
    <div class="step">
      <div class="step-number">4</div>
      <div class="step-content">
        <h3 class="step-title">{t.step4Title}</h3>
        <p class="step-desc">{t.step4Desc}</p>
      </div>
    </div>

  </div>

  <!-- How to use -->
  <div class="how-to-use">
    <h2 class="section-title">{t.howToUse}</h2>
    <p class="section-desc">{t.howToUseDesc}</p>
    <div class="examples">
      <div class="example-item">
        <span class="example-icon">💬</span>
        <span class="example-text">"{t.example1}"</span>
      </div>
      <div class="example-item">
        <span class="example-icon">💬</span>
        <span class="example-text">"{t.example2}"</span>
      </div>
      <div class="example-item">
        <span class="example-icon">💬</span>
        <span class="example-text">"{t.example3}"</span>
      </div>
    </div>
  </div>

  <!-- Parameters table -->
  <div class="params-section">
    <h2 class="section-title">{t.params}</h2>
    <table class="params-table">
      <thead>
        <tr>
          <th>Parameter</th>
          <th></th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><code>toNumber</code></td>
          <td><span class="badge-required">{t.required}</span></td>
          <td>{t.paramTo}</td>
        </tr>
        <tr>
          <td><code>text</code></td>
          <td><span class="badge-required">{t.required}</span></td>
          <td>{t.paramText}</td>
        </tr>
        <tr>
          <td><code>fromNumber</code></td>
          <td><span class="badge-optional">{t.optional}</span></td>
          <td>{t.paramFrom}</td>
        </tr>
      </tbody>
    </table>
  </div>

</div>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const code = btn.getAttribute('data-code') || '';
      navigator.clipboard.writeText(code).then(() => {
        btn.textContent = '✓ Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
      });
    });
  });
</script>

<style>
  .mcp-tool {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* Info card */
  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.75rem;
    background: linear-gradient(135deg, #f0fdff 0%, #f5f0ff 100%);
    border: 1px solid #c4f0f8;
    border-radius: 1rem;
  }
  .info-icon { font-size: 2rem; flex-shrink: 0; }
  .info-title { font-size: 1.25rem; font-weight: 700; color: #0f172a; margin-bottom: 0.5rem; }
  .info-desc { color: #475569; line-height: 1.6; margin: 0; }

  /* Badges */
  .badges { display: flex; gap: 1rem; flex-wrap: wrap; }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .badge:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0,0,0,0.12); }
  .badge-npm { background: #cb3837; color: white; }
  .badge-github { background: #24292e; color: white; }
  .badge-icon { font-size: 1rem; }

  /* Steps */
  .steps { display: flex; flex-direction: column; gap: 1.5rem; }
  .step {
    display: flex;
    gap: 1.5rem;
    padding: 1.75rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    transition: box-shadow 0.2s;
  }
  .step:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.07); }
  .step-number {
    width: 2.5rem;
    height: 2.5rem;
    min-width: 2.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, #26c6da 0%, #7c4dff 100%);
    color: white;
    font-weight: 800;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
